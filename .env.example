# Local development environment variables for `tpu_est`.
#
# 1. Copy this file to `.env` (which is gitignored — never commit real values):
#       Copy-Item .env.example .env
# 2. Fill in the REQUIRED values below.
# 3. Either:
#    - Open the project in VS Code and use the "Run once (local)" launch config
#      (it reads .env automatically via .vscode/launch.json's envFile), OR
#    - Source it manually into your PowerShell session:
#        Get-Content .env | Where-Object { $_ -and -not $_.StartsWith('#') } | ForEach-Object {
#          $name,$value = $_ -split '=',2; [Environment]::SetEnvironmentVariable($name, $value)
#        }
#      then run: python -m tpu_est run-once

# ────────────────── REQUIRED ──────────────────

# Full Foundry inference endpoint (NOT the portal URL).
# Format: https://<account-name>.services.ai.azure.com/models
FOUNDRY_ENDPOINT=https://your-foundry-account.services.ai.azure.com/models

# Name of the deployed model in your Foundry project (NOT the model family).
MODEL_DEPLOYMENT=gpt-5.4

# ────────────────── OPTIONAL (defaults shown) ──────────────────

# Client ID (GUID) of the user-assigned Managed Identity granted
# `Cognitive Services User` on the Foundry account. The deployed Container
# Apps Job sets this from Bicep so DefaultAzureCredential pins to the MI.
#
# LEAVE UNSET LOCALLY: with no AZURE_CLIENT_ID, DefaultAzureCredential falls
# through to AzureCliCredential and uses your `az login` session. If you set
# this on a laptop without that exact MI, the credential chain spends 5–30s
# probing IMDS before falling back — slow and noisy.
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Token sizing — keep small for local sanity checks; the deployed Job uses
# 30000/700000 by default to match production traffic shape.
MIN_TOKENS=1000
MAX_TOKENS=2000

# Per-execution random sleep (seconds) before the API call. Use 0 locally
# so debugging is responsive; the deployed Job uses 179 to decorrelate from
# the cron tick.
MAX_JITTER_SECONDS=0

# How long to wait before the one-shot retry on 401/403 (MI propagation lag).
AUTH_RETRY_SECONDS=60

# Azure OpenAI / Foundry inference REST API version. The default matches what
# the GA `openai/v1` route accepts; override only if your account requires a
# different version (preview accounts sometimes need a `-preview` suffix).
API_VERSION=2025-05-01

# Logging verbosity. One of: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=DEBUG

# Set to make prompt-size and corpus-chunk selection deterministic across
# runs (useful when capturing reference traces). Leave unset for production.
# RANDOM_SEED=42
