# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.env
.env.*
!.env.example

# Bicep compiled output (generated by `az bicep build`)
infra/main.json
infra/modules/*.json

# azd local environment state (per-machine; do not commit)
.azure/
